{
  "name": "control-cajas",
  "version": "1.0.0",
  "description": "Sistema de gestión de cajas - ControlCajas",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint .",
    "seed": "node scripts/seed.js",
    "preview": "npx wrangler pages dev ./",
    "deploy": "npx wrangler pages deploy ./",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "js-cookie": "^3.0.5",
    "mongodb": "^6.3.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/mongodb": "^4.0.6",
    "@types/node": "^20.10.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.16",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "wrangler": "^4.76.0"
  }
}
